# Copie ce fichier en .env puis adapte les valeurs.
# Commande Windows : copy .env.example .env
# Commande Linux   : cp .env.example .env

# ─── Obligatoire ─────────────────────────────────────────────────────────────

# Code organisateur pour déverrouiller la page Admin (défaut : zepadmin).
# Choisis un code solide, surtout si l'app est en ligne.
ADMIN_CODE="change-moi"

# ─── Optionnel ───────────────────────────────────────────────────────────────

# Port d'écoute (défaut : 4173).
# Sur un VPS derrière Caddy/Nginx, laisse 4173 ; le proxy gère le 443.
# PORT=4173

# Faire confiance aux en-têtes proxy pour identifier l'IP du votant.
# À mettre à 1 si l'app est derrière Caddy, Nginx, Cloudflare, ngrok, etc.
# Ne PAS mettre à 1 si tu utilises localhost / WiFi local uniquement.
# TRUST_PROXY=1

# URL publique stable de l'app (domaine ou sous-domaine).
# La page QR et le lien à partager utilisent cette URL.
# Exemple VPS    : PUBLIC_URL=https://zeprasso.mondomaine.com
# Exemple tunnel : PUBLIC_URL=https://pc.zeprasso.ts.net
# PUBLIC_URL=https://zeprasso.mondomaine.com
