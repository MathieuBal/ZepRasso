# Copie ce fichier en .env (commande : copy .env.example .env  sous Windows)
# puis modifie les valeurs. Au prochain `npm start` / `npm run share`, le
# serveur lit automatiquement ce fichier — plus besoin de retaper le code.

# Code organisateur pour deverrouiller la page Admin (defaut : zepadmin)
ADMIN_CODE="change-moi"

# Port du serveur local (defaut : 4173)
PORT=4173

# Faire confiance aux en-tetes proxy pour identifier l'IP du votant.
# Active automatiquement avec `npm run share` (tunnel cloudflared).
# A activer aussi si tu exposes via Tailscale Funnel, ngrok, etc.
# Ne PAS mettre a 1 si tu utilises localhost / le WiFi local uniquement.
# TRUST_PROXY=1

# URL publique stable (Tailscale Funnel, tunnel nomme Cloudflare, etc.)
# Si elle est definie, la page QR et le lien a partager utilisent cette
# URL au lieu de localhost ou de l'adresse WiFi locale.
# Exemple : PUBLIC_URL=https://pc.zeprasso.ts.net
