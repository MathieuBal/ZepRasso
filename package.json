{
  "name": "zeprasso",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "node --env-file-if-exists=.env server/index.mjs",
    "serve": "node --env-file-if-exists=.env server/index.mjs",
    "start": "npm run build && node --env-file-if-exists=.env server/index.mjs",
    "share": "npm run build && node --env-file-if-exists=.env server/index.mjs --tunnel",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "express": "^4.21.2",
    "lucide-react": "^1.16.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.1.7"
  }
}
